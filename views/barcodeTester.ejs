<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<title>Barcode Tester</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body class="bg-light">

<div class="container py-5">

<div class="card shadow">

<div class="card-header">

<h3>

Barcode Tester

</h3>

</div>

<div class="card-body">

<form
action="/dev/barcode"
method="POST"
enctype="multipart/form-data">

<div class="mb-3">

<input
type="file"
name="barcode"
class="form-control">

</div>

<button
class="btn btn-success">

Decode
<% if(result){ %>

<hr>

<div class="alert alert-success">

    <h5>File berhasil diupload</h5>

    <p><%= result.originalname %></p>

    <p><%= result.filename %></p>

</div>

<% } %>

</button>

</form>

</div>

</div>

</div>

</body>

</html>