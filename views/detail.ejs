<!DOCTYPE html>
<html lang="en">

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1">

<title>Monitoring QC IT Support</title>

<link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
    rel="stylesheet">

<link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<link
    rel="stylesheet"
    href="/css/app.css">

</head>

<body>

<%- include("partials/navbar") %>

<%
let lastQc = "-";

if (item.last_qc) {

    const date = new Date(item.last_qc);

    lastQc = date.toLocaleString("id-ID", {
        timeZone: "Asia/Jakarta",
        day: "2-digit",
        month: "long",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false
    }) + " WIB";

}
%>

<div class="container py-4">

<div class="container py-4">

    <!-- Breadcrumb -->

    <nav aria-label="breadcrumb" class="mb-4">

        <ol class="breadcrumb">

            <li class="breadcrumb-item">

                <a href="/">

                    Dashboard

                </a>

            </li>

            <li class="breadcrumb-item">

                <a href="/inventaris">

                    Inventaris

                </a>

            </li>

            <li class="breadcrumb-item active">

                Detail Inventaris

            </li>

        </ol>

    </nav>

    <div class="inventory-detail-card">

        <!-- HEADER -->

        <div class="detail-header">

            <div>

                <div class="detail-category">

                    <i class="bi bi-laptop me-2"></i>

                    DETAIL INVENTARIS

                </div>

                <h2 class="detail-title">

                    <%= item.merk %>

                    <%= item.type %>

                </h2>

                <p class="detail-subtitle">

                    Nomor Faktur :

                    <strong>

                        <%= item.nf %>

                    </strong>

                </p>

            </div>

            <div>

                <% if(item.status==="DONE"){ %>

                    <span class="status-pill status-done">

                        <i class="bi bi-check-circle-fill me-2"></i>

                        DONE

                    </span>

                <% }else if(item.status==="REJECT"){ %>

                    <span class="status-pill status-reject">

                        <i class="bi bi-x-circle-fill me-2"></i>

                        REJECT

                    </span>

                <% }else{ %>

                    <span class="status-pill status-pending">

                        <i class="bi bi-hourglass-split me-2"></i>

                        PENDING

                    </span>

                <% } %>

            </div>

        </div>

        <hr class="my-4">

        <div class="row g-4">

            <!-- LEFT -->

            <div class="col-lg-8">

                <div class="info-section">

                    <h5 class="section-title">

                        <i class="bi bi-info-circle-fill me-2"></i>

                        Informasi Perangkat

                    </h5>

                    <div class="row g-4">

                        <div class="col-md-6">

                            <div class="info-item">

                                <div class="info-label">

                                    <i class="bi bi-pc-display-horizontal"></i>

                                    Merk

                                </div>

                                <div class="info-value">

                                    <%= item.merk %>

                                </div>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="info-item">

                                <div class="info-label">

                                    <i class="bi bi-tag-fill"></i>

                                    Type

                                </div>

                                <div class="info-value">

                                    <%= item.type %>

                                </div>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="info-item">

                                <div class="info-label">

                                    <i class="bi bi-cpu-fill"></i>

                                    Processor

                                </div>

                                <div class="info-value">

                                    <%= item.gen || "-" %>

                                </div>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="info-item">

                                <div class="info-label">

                                    <i class="bi bi-memory"></i>

                                    RAM

                                </div>

                                <div class="info-value">

                                    <%= item.ram || "-" %>

                                </div>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="info-item">

                                <div class="info-label">

                                    <i class="bi bi-phone-fill"></i>

                                    IMEI / Serial Number

                                </div>

                                <div class="info-value">

                                    <%= item.imei || "-" %>

                                </div>

                            </div>

                        </div>

                        <div class="col-md-6">

                            <div class="info-item">

                                <div class="info-label">

                                    <i class="bi bi-upc-scan"></i>

                                    Nomor Faktur

                                </div>

                                <div class="info-value">

                                    <%= item.nf %>

                                </div>

                            </div>

                        </div>

                    </div>

                </div>


<div class="info-section mt-4">

    <h5 class="section-title">

        <i class="bi bi-clipboard-check-fill me-2"></i>

        Status QC

    </h5>

    <div class="row g-4">

        <div class="col-md-6">

            <div class="info-item">

                <div class="info-label">

                    <i class="bi bi-flag-fill"></i>

                    Status QC

                </div>

                <div class="info-value">

                    <% if(item.status==="DONE"){ %>

                        <span class="badge bg-success px-3 py-2">

                            DONE

                        </span>

                    <% }else if(item.status==="REJECT"){ %>

                        <span class="badge bg-danger px-3 py-2">

                            REJECT

                        </span>

                    <% }else{ %>

                        <span class="badge bg-warning text-dark px-3 py-2">

                            PENDING

                        </span>

                    <% } %>

                </div>

            </div>

        </div>

        <div class="col-md-6">

            <div class="info-item">

                <div class="info-label">

                    <i class="bi bi-clock-history"></i>

                    Last QC

                </div>

                <div class="info-value">

                    <%= lastQc %>

                </div>

            </div>

        </div>

<% if(item.status === "REJECT"){ %>

<div class="col-12">

    <div class="info-item">

        <div class="info-label">

            <i class="bi bi-exclamation-octagon-fill"></i>

            Alasan Reject

        </div>

        <div class="info-value text-danger fw-bold">

            <%= item.reject_reason %>

        </div>

    </div>

</div>

<% } %>

    </div>

</div>


<!-- ===========================
     MANUAL QC ACTION
=========================== -->

<div class="info-section mt-4">

    <h5 class="section-title">

        <i class="bi bi-check2-square me-2"></i>

        Manual QC

    </h5>

    <% if(item.status === "PENDING"){ %>

    <form
        action="/inventaris/<%= item.id %>/manual-qc"
        method="POST">

        <div class="mb-3">

            <label
                for="rejectReason"
                class="form-label fw-semibold">

                Reject Reason
                <span class="text-danger">*</span>

            </label>

            <textarea
                id="rejectReason"
                name="reject_reason"
                rows="4"
                class="form-control"
                placeholder="Masukkan alasan reject..."></textarea>

            <div
                id="rejectWarning"
                class="text-danger mt-2 fw-semibold">

                <i class="bi bi-exclamation-circle-fill me-1"></i>

                Isi alasan reject terlebih dahulu.

            </div>

        </div>

        <div class="row g-2">

            <div class="col">

                <button
                    id="doneBtn"
                    type="submit"
                    name="status"
                    value="DONE"
                    class="btn btn-success w-100">

                    <i class="bi bi-check-circle me-2"></i>

                    Done

                </button>

            </div>

            <div class="col">

                <button
                    id="rejectBtn"
                    type="submit"
                    name="status"
                    value="REJECT"
                    class="btn btn-danger w-100"
                    disabled
                    title="Isi Reject Reason terlebih dahulu">

                    <i class="bi bi-x-circle me-2"></i>

                    Reject

                </button>

            </div>

        </div>

    </form>

    <% } else { %>

<div class="alert alert-info mb-3">

    <i class="bi bi-info-circle me-2"></i>

    Inventaris ini sudah selesai QC.

</div>

<form
    id="editQcForm"
    action="/inventaris/<%= item.id %>/edit-qc"
    method="POST">

    <button
        id="editQcBtn"
        type="button"
        class="btn btn-warning w-100">

        <i class="bi bi-check-circle-fill me-2"></i>

        Edit QC

    </button>

</form>

<% } %>

</div>

</div> <!-- END col-lg-8 -->
<!-- ===========================
     RIGHT PANEL
=========================== -->

<div class="col-lg-4">

    <div class="device-card">

        <div class="device-image">

            <%
    let deviceImage = "default.png";

    const jenis = (item.jenis || "").toLowerCase();
    const merk = (item.merk || "").toLowerCase();

    if(jenis === "handphone"){

        // ===== HANDPHONE =====

        deviceImage = "defaulthp.png";

        if(merk.includes("oppo")){

            deviceImage = "oppo.png";

        }else if(merk.includes("samsung")){

            deviceImage = "samsung.png";

        }

    }else{

        // ===== LAPTOP =====

        if(merk.includes("dell")) deviceImage = "dell.png";
        else if(merk.includes("hp")) deviceImage = "hp.png";
        else if(merk.includes("lenovo")) deviceImage = "lenovo.png";
        else if(merk.includes("asus")) deviceImage = "asus.png";
        else if(merk.includes("acer")) deviceImage = "acer.png";
        else if(merk.includes("axioo")) deviceImage = "axioo.png";

    }
%>

            <img
                src="/images/device/<%= deviceImage %>"
                class="img-fluid">

        </div>

        <h4 class="mt-4 mb-1">

            <%= item.merk %>

        </h4>

        <p class="text-muted">

            <%= item.type %>

        </p>

    </div>

    <div class="device-card mt-4">

        <h5 class="mb-4">

            <i class="bi bi-camera-fill me-2"></i>

            Foto QC

        </h5>

        <% if(item.photo_path){ %>

            <img

                src="<%= item.photo_path %>"

                class="photo-preview w-100"

                style="cursor:pointer"

                data-bs-toggle="modal"

                data-bs-target="#photoModal">

            <button

                class="btn btn-success w-100 mt-3"

                data-bs-toggle="modal"

                data-bs-target="#photoModal">

                <i class="bi bi-image-fill me-2"></i>

                Lihat Foto QC

            </button>

        <% }else{ %>

            <div class="empty-photo">

                <i class="bi bi-image fs-1"></i>

                <p class="mt-3 mb-0">

                    Belum ada Foto QC

                </p>

            </div>

        <% } %>

    </div>

</div>

</div>

<hr class="my-4">

<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

    <a
        href="/inventaris"
        class="btn btn-outline-secondary px-4">

        <i class="bi bi-arrow-left me-2"></i>

        Kembali ke Inventaris

    </a>

    <div>

        <span class="badge bg-primary fs-6 px-3 py-2">

            <i class="bi bi-upc-scan me-2"></i>

            <%= item.nf %>

        </span>

        <button

            class="btn btn-primary ms-2"

            onclick="copyNF()">

            <i class="bi bi-copy me-2"></i>

            Copy NF

        </button>

    </div>

</div>

</div>

</div>
<!-- ===========================
     PHOTO MODAL
=========================== -->

<% if(item.photo_path){ %>

<div
    class="modal fade"
    id="photoModal"
    tabindex="-1"
    aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered">

        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header">

                <h5 class="modal-title">

                    <i class="bi bi-camera-fill me-2"></i>

                    Foto QC

                </h5>

                <button
                    type="button"
                    class="btn-close"
                    data-bs-dismiss="modal">

                </button>

            </div>

            <div class="modal-body text-center bg-light">

                <img

                    src="<%= item.photo_path %>"

                    class="img-fluid rounded">

            </div>

            <div class="modal-footer">

                <a

                    href="<%= item.photo_path %>"

                    download

                    class="btn btn-success">

                    <i class="bi bi-download me-2"></i>

                    Download Foto

                </a>

                <button

                    class="btn btn-secondary"

                    data-bs-dismiss="modal">

                    Tutup

                </button>

            </div>

        </div>

    </div>

</div>

<% } %>

<%- include("partials/footer") %>
<!-- =====================================
     TOAST NOTIFICATION
====================================== -->

<div
    class="toast-container position-fixed top-0 end-0 p-3"
    style="z-index:2000;">

    <!-- DONE -->

    <% if(success === "done"){ %>

    <div
        id="liveToast"
        class="toast toast-success border-0 shadow-lg">

        <div class="d-flex">

            <div class="toast-body">

                <div class="fw-bold mb-1">

                    <i class="bi bi-check-circle-fill me-2"></i>

                    QC Berhasil

                </div>

                Inventaris berhasil diubah menjadi
                <strong>DONE</strong>.

            </div>

            <button
                type="button"
                class="btn-close btn-close-white me-3 mt-3"
                data-bs-dismiss="toast"
                aria-label="Close">
            </button>

        </div>

    </div>

    <% } %>



    <!-- REJECT -->

    <% if(success === "reject"){ %>

    <div
        id="liveToast"
        class="toast toast-danger border-0 shadow-lg">

        <div class="d-flex">

            <div class="toast-body">

                <div class="fw-bold mb-1">

                    <i class="bi bi-x-circle-fill me-2"></i>

                    QC Berhasil

                </div>

                Inventaris berhasil diubah menjadi
                <strong>REJECT</strong>.

            </div>

            <button
                type="button"
                class="btn-close btn-close-white me-3 mt-3"
                data-bs-dismiss="toast"
                aria-label="Close">
            </button>

        </div>

    </div>

    <% } %>

<!-- EDIT QC -->

<% if(success === "edit"){ %>

<div
    id="liveToast"
    class="toast toast-success border-0 shadow-lg">

    <div class="d-flex">

        <div class="toast-body">

            <div class="fw-bold mb-1">

                <i class="bi bi-check-circle-fill me-2"></i>

                Edit QC

            </div>

            Status berhasil dikembalikan menjadi
            <strong>PENDING</strong>.

        </div>

        <button
            type="button"
            class="btn-close btn-close-white me-3 mt-3"
            data-bs-dismiss="toast">
        </button>

    </div>

</div>

<% } %>

<!-- Already Pending -->

<% if(error === "already-pending"){ %>

<div
    id="liveToast"
    class="toast toast-warning border-0 shadow-lg">

    <div class="d-flex">

        <div class="toast-body">

            <div class="fw-bold mb-1">

                <i class="bi bi-info-circle-fill me-2"></i>

                Informasi

            </div>

            Inventaris ini sudah berstatus
            <strong>PENDING</strong>.

        </div>

        <button
            type="button"
            class="btn-close me-3 mt-3"
            data-bs-dismiss="toast">
        </button>

    </div>

</div>

<% } %>


    <!-- Reject Reason Required -->

    <% if(error === "reject-required"){ %>

    <div
        id="liveToast"
        class="toast toast-warning border-0 shadow-lg">

        <div class="d-flex">

            <div class="toast-body">

                <div class="fw-bold mb-1">

                    <i class="bi bi-exclamation-triangle-fill me-2"></i>

                    Peringatan

                </div>

                Reject Reason wajib diisi.

            </div>

            <button
                type="button"
                class="btn-close me-3 mt-3"
                data-bs-dismiss="toast"
                aria-label="Close">
            </button>

        </div>

    </div>

    <% } %>



    <!-- Already QC -->

    <% if(error === "already-qc"){ %>

    <div
        id="liveToast"
        class="toast toast-warning border-0 shadow-lg">

        <div class="d-flex">

            <div class="toast-body">

                <div class="fw-bold mb-1">

                    <i class="bi bi-info-circle-fill me-2"></i>

                    Informasi

                </div>

                Inventaris ini sudah selesai QC.

            </div>

            <button
                type="button"
                class="btn-close me-3 mt-3"
                data-bs-dismiss="toast"
                aria-label="Close">
            </button>

        </div>

    </div>

    <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>

function copyNF(){

    navigator.clipboard.writeText("<%= item.nf %>");

    const toast=document.createElement("div");

    toast.className="copy-toast";

    toast.innerHTML=`
        <i class="bi bi-check-circle-fill me-2"></i>
        Nomor Faktur berhasil disalin
    `;

    document.body.appendChild(toast);

    setTimeout(()=>{

        toast.classList.add("show");

    },50);

    setTimeout(()=>{

        toast.classList.remove("show");

    },1800);

    setTimeout(()=>{

        toast.remove();

    },2200);

}
const rejectReason = document.getElementById("rejectReason");
const rejectBtn = document.getElementById("rejectBtn");
const rejectWarning = document.getElementById("rejectWarning");

if (rejectReason) {

    function validateRejectReason() {

        const hasReason = rejectReason.value.trim().length > 0;

        rejectBtn.disabled = !hasReason;

        rejectWarning.style.display = hasReason
            ? "none"
            : "block";
    }

    rejectReason.addEventListener("input", validateRejectReason);

    validateRejectReason();
    
}
/* ===========================
   Toast
=========================== */

const toastElement =
document.getElementById("liveToast");

if (toastElement) {

    const toast =
        new bootstrap.Toast(toastElement, {

            delay:3000

        });

    toast.show();

}
if (
    window.location.search.includes("success") ||
    window.location.search.includes("error")
) {

    window.history.replaceState(
        {},
        document.title,
        window.location.pathname
    );

}
/* ===========================
   Edit QC Confirmation
=========================== */

const editQcBtn = document.getElementById("editQcBtn");

if (editQcBtn) {

    editQcBtn.addEventListener("click", () => {

        Swal.fire({

            icon: "warning",

            title: "Edit Hasil QC",

            html: `
                Status inventaris akan dikembalikan menjadi
                <b>PENDING</b>.<br>
                Anda dapat melakukan QC ulang.
            `,

            showCancelButton: true,

            confirmButtonText: '<i class="bi bi-pencil-square me-1"></i> Ya, Edit',

            cancelButtonText: '<i class="bi bi-x-circle me-1"></i> Batal',

            confirmButtonColor: "#f59e0b",

            cancelButtonColor: "#6c757d",

            reverseButtons: true,

            focusCancel: true

        }).then((result) => {

            if (result.isConfirmed) {

                document
                    .getElementById("editQcForm")
                    .submit();

            }

        });

    });

}
/* ===========================
   Manual QC Confirmation
=========================== */

const doneBtn = document.getElementById("doneBtn");
const manualQcForm = doneBtn?.closest("form");

// =====================
// DONE
// =====================

if (doneBtn && manualQcForm) {

    doneBtn.addEventListener("click", function (e) {

        e.preventDefault();

        Swal.fire({

            icon: "question",

            title: "Konfirmasi DONE",

            text: "Apakah Anda yakin ingin mengubah status inventaris menjadi DONE?",

            showCancelButton: true,

            confirmButtonText: "Ya, DONE",

            cancelButtonText: "Batal",

            confirmButtonColor: "#198754",

            cancelButtonColor: "#6c757d",

            reverseButtons: true,

            focusCancel: true

        }).then((result) => {

            if (result.isConfirmed) {

                manualQcForm.requestSubmit(doneBtn);

            }

        });

    });

}

// =====================
// REJECT
// =====================

if (rejectBtn && manualQcForm) {

    rejectBtn.addEventListener("click", function (e) {

        e.preventDefault();

        Swal.fire({

            icon: "warning",

            title: "Konfirmasi REJECT",

            html: `
                Apakah Anda yakin ingin mengubah status inventaris menjadi <b>REJECT</b>?
                <br><br>

                <div class="text-start">

                    <strong>Reject Reason :</strong>

                    <div class="mt-2 p-2 bg-light rounded border">

                        ${rejectReason.value}

                    </div>

                </div>
            `,

            showCancelButton: true,

            confirmButtonText: "Ya, REJECT",

            cancelButtonText: "Batal",

            confirmButtonColor: "#dc3545",

            cancelButtonColor: "#6c757d",

            reverseButtons: true,

            focusCancel: true

        }).then((result) => {

            if (result.isConfirmed) {

                manualQcForm.requestSubmit(rejectBtn);

            }

        });

    });

}

</script>

</body>

</html>